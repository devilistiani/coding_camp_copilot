# ── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=Coding Camp Copilot Backend

# ── Database ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://copilot:copilot_pass@localhost:5432/copilot_db?schema=public

# ── Auth (JWT) ──────────────────────────────────────────────
# Pakai random string panjang. Generate via: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_random_64char_hex_string
JWT_REFRESH_SECRET=replace_with_DIFFERENT_random_64char_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list. Gunakan "*" hanya untuk development.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
