    {
      "name": "Admin",
      "description": "Admin-only endpoints + Logout cleanup.\n\nFolder ini diawali dengan **Login (Admin)** yang override `access_token` dari Peserta → semua endpoint berikutnya jalan sebagai admin.\n\nDiakhiri dengan **Logout** sebagai cleanup.",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
