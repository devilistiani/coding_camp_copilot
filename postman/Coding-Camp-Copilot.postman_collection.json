                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Conversation ID konsisten', function () {",
                  "    pm.expect(json.data.conversation.id).to.eql(pm.environment.get('last_conversation_id'));",
