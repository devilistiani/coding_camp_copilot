        {
          "name": "Analytics Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const d = pm.response.json().data;",
                  "console.log('Users:', d.users.total, '(active:', d.users.active + ')');",
                  "console.log('Conversations:', d.conversations.total, '| today:', d.conversations.new_today);",
                  "console.log('Messages:', d.messages.total, '| AI:', d.messages.by_sender.ai);",
                  "console.log('Avg confidence:', d.ai.avg_confidence !== null ? (d.ai.avg_confidence * 100).toFixed(1) + '%' : 'N/A');",
                  "console.log('Trend 30d points:', d.daily_trend_last_30_days.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/analytics/summary",
              "host": ["{{base_url}}"],
              "path": ["admin", "analytics", "summary"]
            },
            "description": "Aggregated analytics: users, conversations, messages, AI (confidence, kategori, urgensi), daily trend 30 hari."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('last_target_user_id')) {",
                  "    console.warn('Skip Delete User: last_target_user_id kosong');",
                  "    postman.setNextRequest('Logout');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "console.log('User dihapus:', pm.environment.get('last_target_user_email'));",
                  "pm.environment.unset('last_target_user_id');",
                  "pm.environment.unset('last_target_user_email');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/{{last_target_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{last_target_user_id}}"]
            },
            "description": "Hapus user permanen (cascade: refresh_tokens + conversations + messages). Self-protection: admin tidak bisa hapus akun sendiri.\n\nPre-request: skip kalau `last_target_user_id` kosong (akun seed `peserta@` & `admin@` aman, gak akan ke-target)."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 (idempotent)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.environment.unset('access_token');",
                  "pm.environment.unset('refresh_token');",
                  "pm.environment.unset('current_user_id');",
                  "pm.environment.unset('current_user_email');",
                  "pm.environment.unset('current_user_role');",
                  "console.log('Logout — token cleared');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revoke refresh token. Idempotent — tidak error walaupun token sudah di-revoke."
          },
          "response": []
        }
      ]
    },
