                  "console.log('Profile updated:', json.data.user.name);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Peserta Update Test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Update profile peserta. Field yang bisa diupdate: `full_name` (min 2, max 150)."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('access_token', json.data.token);",
                  "pm.environment.set('refresh_token', json.data.refresh_token);",
                  "console.log('Token di-refresh & rotated');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Tukar refresh token dengan access token baru. Token rotation — refresh token lama dicabut, dapat refresh token baru."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "description": "Chat & conversation endpoints — semua test pakai token Peserta (dari folder Auth sebelumnya).\n\nRate limit: 30/min/user untuk `/chat` & `/predict`. Latensi `/chat` & `/predict` ~2–5 detik (Gemini call).",
      "item": [
        {
          "name": "Send Chat (New Conversation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response has conversation + messages', function () {",
                  "    pm.expect(json.data.conversation.id).to.be.a('string');",
                  "    pm.expect(json.data.user_message).to.be.an('object');",
                  "    pm.expect(json.data.ai_message).to.be.an('object');",
                  "});",
                  "pm.environment.set('last_conversation_id', json.data.conversation.id);",
                  "console.log('Conversation:', json.data.conversation.id);",
                  "console.log('Kategori:', json.data.ai_message.category, '| Urgency:', json.data.ai_message.urgency, '| Confidence:', json.data.ai_message.confidence);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Kapan deadline submission capstone?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat",
              "host": ["{{base_url}}"],
              "path": ["chat"]
            },
            "description": "Kirim pertanyaan ke AI tanpa `conversation_id` → bikin conversation baru. `conversation.id` auto-save ke `{{last_conversation_id}}`."
          },
          "response": []
        },
        {
